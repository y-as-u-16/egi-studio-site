# Public site origin used for metadata, canonical URLs, sitemap, and robots.txt.
# GitHub Pages project site example:
NEXT_PUBLIC_SITE_URL=

# Set only when deploying under a subpath such as GitHub Pages project sites.
# For https://y-as-u-16.github.io/egi-studio-site/, use:
NEXT_PUBLIC_BASE_PATH=

# Future custom domain example:
# NEXT_PUBLIC_SITE_URL=https://egi-studio.com
# NEXT_PUBLIC_BASE_PATH=
