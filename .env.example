# Public site origin used for metadata, canonical URLs, sitemap, and robots.txt.
# Custom domain example:
NEXT_PUBLIC_SITE_URL=https://studio.egi-engineer.com

# Set only when deploying under a subpath such as GitHub Pages project sites.
# Keep this empty for a custom domain such as https://studio.egi-engineer.com/.
NEXT_PUBLIC_BASE_PATH=

# GitHub Pages project site example without a custom domain:
# NEXT_PUBLIC_SITE_URL=https://y-as-u-16.github.io
# NEXT_PUBLIC_BASE_PATH=/egi-studio-site
